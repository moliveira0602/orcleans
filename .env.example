# ORCA Lens - Environment Variables
# Copy this file to .env and fill in your API keys

# Foursquare Places API Key (free, 950 requests/day)
# Get from: https://foursquare.com/developers/
# → Create App → Copy API Key
VITE_FSQ_API_KEY=

# Notes:
# - Overpass API (OpenStreetMap) is used by default and is 100% free
# - Add Foursquare key to get phone, website, address, ratings, and photos
# - If no key is configured, the app will still work but won't show enriched data
# - The app will log "[Enrichment] Foursquare API key not configured" if missing