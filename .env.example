# ORCA Lens - Environment Variables
# Copy this file to .env and fill in the real values (NEVER commit .env)

# Frontend URL
FRONTEND_URL=https://orcaleads.online

# API URL for backend
VITE_API_URL=https://orca-api-etos.vercel.app/api

# Google Places API Key
# Get your key from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# OpenRouter API Key for AI Analysis
# Get from: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE

# Stripe
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Optional: Foursquare Places API Key (free, 950 requests/day)
# Get from: https://foursquare.com/developers/
VITE_FSQ_API_KEY=
