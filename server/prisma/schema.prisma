generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  seed         = "tsx prisma/seed.ts"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String   @id @default(uuid())
  name            String
  plan            String   @default("trial")
  maxLeads        Int      @default(25)
  leadsConsumed   Int      @default(0)
  maxImportBatch  Int      @default(50)
  maxUsers        Int      @default(1)
  trialExpiresAt  DateTime?
  lastBillingDate DateTime @default(now())
  stripeId        String?
  apiKey          String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users       User[]
  leads       Lead[]
  activities  Activity[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  email          String   @unique
  passwordHash   String
  role           String   @default("member")
  avatarUrl      String?
  company        String?
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?
  lastSeenAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens  RefreshToken[]
  activities     Activity[]
  leads          Lead[]
  leadInteractions LeadInteraction[]

  @@index([organizationId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Lead {
  id            String   @id @default(uuid())
  organizationId String
  userId        String?  // Usuário que criou/importou o lead
  nome          String
  segmento      String   @default("")
  avaliacao     Float?
  reviews       Int?
  preco         String   @default("")
  endereco      String   @default("")
  cidade        String   @default("")
  status        String   @default("")
  horario       String   @default("")
  telefone      String   @default("")
  website       String   @default("")
  email         String   @default("")
  servicos      String[] @default([])
  foto          String   @default("")
  fotos         String[] @default([])
  linkOrigem    String   @default("")
  linkPedido    String   @default("")
  observacoes   String   @default("")
  score         Int      @default(0)
  outcomeScore  Float    @default(0) // Inteligência adaptativa baseada em resultados
  lastOutcome   String?  // 'converteu', 'rejeitou', 'interessado'
  pipelineStage String   @default("novo")
  lat           Float?
  lng           Float?
  geocodeStatus String   @default("pending")
  insight       Json?
  notes         Json?    @default("[]")
  raw           Json?
  importFile    String?
  importDate    DateTime?
  importId      String?
  lastContact   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  activities    Activity[]
  interactions  LeadInteraction[]

  @@index([organizationId])
  @@index([userId])
  @@index([pipelineStage])
  @@index([score])
  @@index([createdAt])
  @@index([segmento])
  @@map("leads")
}

model LeadInteraction {
  id             String   @id @default(uuid())
  leadId         String
  userId         String
  type           String   // 'call', 'email', 'whatsapp', 'meeting'
  outcome        String   // 'answered', 'no_answer', 'converted', 'rejected'
  notes          String   @default("")
  createdAt      DateTime @default(now())

  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([userId])
  @@index([createdAt])
  @@map("lead_interactions")
}

model Activity {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  title          String
  sub            String   @default("")
  icon           String   @default("")
  channel        String   @default("system")
  leadId         String?
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@map("activities")
}

model AuditLog {
  id            String   @id @default(uuid())
  userId        String?
  userEmail     String?
  action        String
  entityType    String   @default("")
  entityId      String?
  details       Json     @default("{}")
  ipAddress     String?
  userAgent     String?
  organizationId String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemConfig {
  id              String   @id @default("global")
  maintenanceMode Boolean  @default(false)
  maintenanceMsg  String   @default("Estamos em manutenção para melhorar a sua experiência. Voltamos em breve!")
  updatedAt       DateTime @updatedAt

  @@map("system_config")
}
